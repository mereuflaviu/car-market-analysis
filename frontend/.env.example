# API base URL
# - Docker / production: leave empty or use /api (nginx proxies it)
# - Local dev without Docker: http://localhost:8001/api
# Leave blank to use the hardcoded fallback in src/api/client.js
VITE_API_URL=

# Optional API key for the legacy mutation guard (only relevant when backend ENV=production).
# WARNING: This value is baked into the compiled JS bundle at build time and is
# publicly visible in the browser. Do NOT put a high-value secret here.
# The backend uses this as a lightweight abuse guard, not a real secret.
VITE_API_KEY=
