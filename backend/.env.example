# ── Environment ───────────────────────────────────────────────────────────────
# "development" skips API key enforcement; "production" enforces it
ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Required in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── First admin ───────────────────────────────────────────────────────────────
# The first user to register with this email is automatically made admin
FIRST_ADMIN_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173
